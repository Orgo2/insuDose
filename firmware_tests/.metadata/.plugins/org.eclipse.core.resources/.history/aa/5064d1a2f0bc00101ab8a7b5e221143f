#include "MIC.h"
#include "sai.h"
#include "gpio.h"
#include "main.h"
#include <math.h>
#include <string.h>

// Globálne buffery pre audio dáta (minimalizované pre nízku spotrebu)
static int16_t audioBuffer[MIC_BUFFER_SIZE];
static int16_t processedBuffer[MIC_BUFFER_SIZE / 2];
static volatile bool recording = false;
static volatile bool stopRequested = false;

// PDM to PCM konverzia (decimácia)
static PDM_Filter_Handler_t PDM_FilterHandler;
static PDM_Filter_Config_t PDM_FilterConfig;

// Inicializácia mikrofónu
void MIC_Init(void) {
    // 1. Zapnutie napájania mikrofónu
    HAL_GPIO_WritePin(PW_MIC_GPIO_Port, PW_MIC_Pin, GPIO_PIN_SET);
    
    // 2. Čakanie na ustálenie napájania
    HAL_Delay(MIC_STABILIZATION_MS);
    
    // 3. Konfigurácia PDM filtra pre decimáciu
    PDM_FilterHandler.bit_order = PDM_FILTER_BIT_ORDER_MSB;
    PDM_FilterHandler.endianness = PDM_FILTER_ENDIANNESS_LE;
    PDM_FilterHandler.high_pass_tap = 2122358088;
    PDM_FilterHandler.out_ptr_channels = 1;
    PDM_FilterHandler.in_ptr_channels = 1;
    
    PDM_Filter_Init(&PDM_FilterHandler);
    
    // Konfigurácia decimácie a filtrácie
    PDM_FilterConfig.output_samples_number = MIC_SAMPLE_RATE / 1000; // Vzorky na ms
    PDM_FilterConfig.mic_gain = 24; // Zosilnenie mikrofónu (0-24 dB)
    PDM_FilterConfig.decimation_factor = PDM_FILTER_DEC_FACTOR_64; // Decimácia 64x
    
    PDM_Filter_setConfig(&PDM_FilterHandler, &PDM_FilterConfig);
    
    // 4. Inicializácia SAI pre PDM mikrofón (už nakonfigurované v sai.c)
    // PA8 = SAI1_CK2 (Clock)
    // PA9 = SAI1_D2 (Data)
    // LR pin uzemnený = ľavý kanál
    
    recording = false;
    stopRequested = false;
}

// Vypnutie mikrofónu
void MIC_DeInit(void) {
    MIC_StopRecording();
    HAL_GPIO_WritePin(PW_MIC_GPIO_Port, PW_MIC_Pin, GPIO_PIN_RESET);
}

// Začatie nahrávania
void MIC_StartRecording(void) {
    if (!recording) {
        recording = true;
        stopRequested = false;
        memset(audioBuffer, 0, sizeof(audioBuffer));
        
        // Spustenie SAI DMA príjmu v PDM režime
        HAL_SAI_Receive_DMA(&hsai_BlockA1, (uint8_t*)audioBuffer, MIC_BUFFER_SIZE);
    }
}

// Zastavenie nahrávania
void MIC_StopRecording(void) {
    if (recording) {
        HAL_SAI_DMAStop(&hsai_BlockA1);
        recording = false;
    }
}

// Zastavenie merania (volá sa z EXTI interrupt DOSE tlačidla)
void MIC_StopMeasurement(void) {
    stopRequested = true;
}

// Goertzelův algoritmus pre detekciu konkrétnej frekvencie (efektívny, nízka spotreba)
// Výpočtovo omnoho lacnejší ako FFT - potrebuje len 2 násobenia a 3 sčítania na vzorku
static float goertzel_magnitude(int16_t* samples, uint32_t num_samples, uint16_t target_freq, uint32_t sample_rate) {
    float k = (int)(0.5f + ((num_samples * target_freq) / (float)sample_rate));
    float omega = (2.0f * M_PI * k) / num_samples;
    float sine = sinf(omega);
    float cosine = cosf(omega);
    float coeff = 2.0f * cosine;
    
    float q0 = 0, q1 = 0, q2 = 0;
    
    for (uint32_t i = 0; i < num_samples; i++) {
        q0 = coeff * q1 - q2 + samples[i];
        q2 = q1;
        q1 = q0;
    }
    
    float real = (q1 - q2 * cosine);
    float imag = (q2 * sine);
    float magnitude = sqrtf(real * real + imag * imag);
    
    return magnitude;
}

// Pásmová priepusť s detekciou frekvencie
BandpassResult_t MIC_BandpassFilter(uint16_t freq_hz, float amplitude) {
    BandpassResult_t result = {0};
    
    // Kontrola platnosti frekvencie
    if (freq_hz > MIC_BANDPASS_MAX_FREQ || freq_hz < 20) {
        result.completed = false;
        return result;
    }
    
    // Inicializácia a spustenie nahrávania
    MIC_StartRecording();
    
    uint32_t detection_count = 0;
    float background_sum = 0;
    uint32_t background_samples = 0;
    float detection_threshold = amplitude;
    bool auto_detect = (amplitude == 0);
    
    // Fáza 1: Ak je amplitude 0, najprv zmeraj pozadie
    if (auto_detect) {
        const uint32_t background_time_ms = 500; // 500ms na meranie pozadia
        uint32_t start_tick = HAL_GetTick();
        
        while ((HAL_GetTick() - start_tick) < background_time_ms && !stopRequested) {
            // Čakanie na DMA half/complete callback
            if (recording) {
                HAL_Delay(10);
                
                // Výpočet magnitudy pre cieľovú frekvenciu
                float magnitude = goertzel_magnitude(audioBuffer, MIC_BUFFER_SIZE / 2, 
                                                     freq_hz, MIC_SAMPLE_RATE);
                background_sum += magnitude;
                background_samples++;
            }
        }
        
        if (background_samples > 0) {
            result.average_background = background_sum / background_samples;
            // Nastavenie prahu na 2x priemer pozadia
            detection_threshold = result.average_background * 2.0f;
        } else {
            detection_threshold = 1000.0f; // Defaultný prah
        }
    }
    
    // Fáza 2: Detekcia frekvencie nad prahom
    while (!stopRequested) {
        if (recording) {
            HAL_Delay(10);
            
            // Výpočet magnitudy pre cieľovú frekvenciu pomocou Goertzelovho algoritmu
            float magnitude = goertzel_magnitude(audioBuffer, MIC_BUFFER_SIZE / 2, 
                                                 freq_hz, MIC_SAMPLE_RATE);
            
            // Kontrola, či prekročila prah
            if (magnitude > detection_threshold) {
                detection_count++;
            }
        }
        
        // Kontrola tlačidla DOSE (EXTI interrupt nastaví stopRequested)
        if (HAL_GPIO_ReadPin(DOSE_GPIO_Port, DOSE_Pin) == GPIO_PIN_RESET) {
            break;
        }
    }
    
    // Zastavenie nahrávania
    MIC_StopRecording();
    
    result.count = detection_count;
    result.completed = true;
    
    return result;
}

// DMA Half Transfer callback
void HAL_SAI_RxHalfCpltCallback(SAI_HandleTypeDef *hsai) {
    if (hsai == &hsai_BlockA1 && recording) {
        // Spracovanie prvej polovice buffera
        PDM_Filter(&audioBuffer[0], processedBuffer, &PDM_FilterHandler);
    }
}

// DMA Complete Transfer callback
void HAL_SAI_RxCpltCallback(SAI_HandleTypeDef *hsai) {
    if (hsai == &hsai_BlockA1 && recording) {
        // Spracovanie druhej polovice buffera
        PDM_Filter(&audioBuffer[MIC_BUFFER_SIZE / 2], processedBuffer, &PDM_FilterHandler);
    }
}


